{
  "expo": {
    "name": "F.R.I.D.A.Y.",
    "description": "Professional AI Assistant with Memory - Iron Man FRIDAY in Your Pocket",
    "slug": "friday-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fridaymobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "primaryColor": "#00D4FF",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ofreyes2.FridayMobile",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "This app connects to local Ollama instance for AI processing",
        "NSBonjourServiceTypes": [
          "_http._tcp"
        ]
      },
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#0A0A0F"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#0A0A0F"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ofreyes2.friday",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#0A0A0F"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0F"
        }
      ],
      "expo-sqlite",
      "@react-native-voice/voice"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dd402b66-9862-4062-9aa0-a65acae581d3"
      }
    },
    "owner": "ofreyes2"
  }
}
